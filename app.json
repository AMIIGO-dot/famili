{
  "expo": {
    "name": "FAMILU",
    "slug": "familj",
    "scheme": "familj",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/FAMILU app icon (1).png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/FAMILU app logo-white(1000 x 500 px).png",
      "resizeMode": "contain",
      "backgroundColor": "#44B57F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.superdevver.familj",
      "icon": "./assets/FAMILU app icon (1).png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "FAMILJ uses your microphone to let you speak event details out loud.",
        "NSSpeechRecognitionUsageDescription": "FAMILJ transcribes your voice to create calendar events."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/FAMILU app icon (1).png",
        "backgroundColor": "#44B57F"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-font",
      "expo-notifications",
      "expo-secure-store",
      [
        "expo-audio",
        {
          "microphonePermission": "FAMILJ uses your microphone to let you speak event details out loud."
        }
      ],

      [
        "expo-widgets",
        {
          "groupIdentifier": "group.com.superdevver.familj",
          "widgets": [
            {
              "name": "TodayWidget",
              "displayName": "FAMILU Idag",
              "description": "Se dagens aktiviteter och lägg till nya med AI",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ]
            }
          ]
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "377b3160-65ec-4d15-be0b-b222c3f4c1f7"
      }
    },
    "owner": "superdevver"
  }
}
