# FAMILJ – Environment Variables
# Copy this file to .env and fill in your Supabase project values.
# Found at: https://supabase.com/dashboard → Project → Settings → API

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# RevenueCat API key
# Found at: https://app.revenuecat.com → Project → API Keys
# A single key works for both iOS and Android (App API Key)
EXPO_PUBLIC_RC_API_KEY=your_revenuecat_api_key_here
