# FAMILJ – Environment Variables
# Copy this file to .env and fill in your Supabase project values.
# Found at: https://supabase.com/dashboard → Project → Settings → API

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# RevenueCat API keys
# Found at: https://app.revenuecat.com → Project → API Keys
EXPO_PUBLIC_RC_IOS_KEY=appl_your_ios_key_here
EXPO_PUBLIC_RC_ANDROID_KEY=goog_your_android_key_here
